{
  "extends": "@tsconfig/node18/tsconfig.json",
  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": false,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "outDir": "build"
  },
  "include": [
    "src",
    "node_modules/@doko/common/@types"
  ]
}